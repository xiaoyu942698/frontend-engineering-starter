# Root template environment inventory.
# Keep values empty or demonstrative; put real local values in ignored .env files.
# App-specific runtime examples still live next to each app, such as apps/web/.env.example.

VITE_API_BASE_URL=
VITE_AUTH_STORAGE_KEY=agent-flow.auth
VITE_REQUEST_TIMEOUT_MS=10000
VITE_ENABLE_MOCK_AUTH=true
