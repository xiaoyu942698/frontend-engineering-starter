{
  "name": "frontend-engineering-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "description": "General-purpose Vue frontend engineering starter with optional agent runtime examples.",
  "scripts": {
    "dev": "pnpm --parallel --filter @agent-flow/mock-api --filter @agent-flow/web dev",
    "dev:web": "pnpm --filter @agent-flow/web dev",
    "dev:api": "pnpm --filter @agent-flow/mock-api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint && eslint . && pnpm lint:style && pnpm lint:standards && pnpm lint:engineering",
    "lint:style": "stylelint \"apps/web/src/**/*.{css,vue}\" \"packages/ui/src/**/*.{css,vue}\"",
    "lint:standards": "node scripts/check-naming-and-comments.mjs",
    "lint:engineering": "node scripts/check-engineering-rules.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test && pnpm test:standards && pnpm test:engineering",
    "test:standards": "node --test scripts/check-naming-and-comments.test.mjs",
    "test:engineering": "node --test scripts/check-engineering-rules.test.mjs scripts/check-gate-closure.test.mjs scripts/check-web-vite-config.test.mjs scripts/configure-github-branch-protection.test.mjs scripts/scaffold-feature.test.mjs",
    "test:coverage": "pnpm --filter @agent-flow/contracts test:coverage && pnpm --filter @agent-flow/mock-api test:coverage && pnpm --filter @agent-flow/web test:coverage",
    "test:e2e": "pnpm --filter @agent-flow/web test:e2e",
    "verify:e2e": "pnpm --filter @agent-flow/web test:e2e",
    "commitlint": "commitlint",
    "protect:github": "node scripts/configure-github-branch-protection.mjs",
    "scaffold:feature": "node scripts/scaffold-feature.mjs",
    "precommit": "lint-staged && pnpm lint:standards && pnpm lint:engineering && pnpm check:gates",
    "check:gates": "node scripts/check-gate-closure.mjs",
    "verify": "pnpm format:check && pnpm lint && pnpm test && pnpm build && pnpm check:gates",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.4.1"
  }
}
